            <ellipse cx="17" cy="158" rx="10" ry="6" fill="#80b860" transform="rotate(-30 17 158)" opacity="0.72"/>
            <ellipse cx="15" cy="175" rx="9"  ry="6" fill="#90c870" transform="rotate(-35 15 175)" opacity="0.67"/>
