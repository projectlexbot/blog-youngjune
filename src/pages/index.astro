            <ellipse cx="68" cy="24" rx="10" ry="5" fill="#98c880" transform="rotate(10 68 24)" opacity="0.72"/>
          </svg>

          <!-- 장식용 책등 (반투명 배경) -->
          <svg class="deco-spines" viewBox="0 0 56 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="1"  y="22" width="12" height="138" fill="#8ab0cc" stroke="#6a90ac" stroke-width="0.5" rx="1" opacity="0.38"/>
            <rect x="15" y="10" width="10" height="150" fill="#c8c070" stroke="#a8a050" stroke-width="0.5" rx="1" opacity="0.38"/>
            <rect x="27" y="28" width="13" height="132" fill="#8abb8a" stroke="#6a9b6a" stroke-width="0.5" rx="1" opacity="0.38"/>
            <rect x="42" y="16" width="11" height="144" fill="#c8a890" stroke="#a88870" stroke-width="0.5" rx="1" opacity="0.38"/>
          </svg>
        </div>

        <!-- 3단 선반 -->
        <div class="shelf-unit">
          <div class="shelf-row"><div class="shelf-books" id="shelf-row-0"></div><div class="shelf-board"></div></div>
          <div class="shelf-row"><div class="shelf-books" id="shelf-row-1"></div><div class="shelf-board"></div></div>
          <div class="shelf-row"><div class="shelf-books" id="shelf-row-2"></div><div class="shelf-board"></div></div>
        </div>

        <!-- 페이지 컨트롤 -->
        <div class="shelf-pagination" id="shelf-pagination">
          <button class="page-btn" id="prev-btn" aria-label="이전 페이지">←</button>
          <div class="page-dots" id="page-dots"></div>
          <button class="page-btn" id="next-btn" aria-label="다음 페이지">→</button>
        </div>
      </div>

      <script is:inline>
      (function() {
        const wrap = document.getElementById('bookshelf');
        const books = JSON.parse(wrap.dataset.books || '[]');
        const PER_PAGE = 9, PER_ROW = 3;
        const totalPages = Math.max(1, Math.ceil(books.length / PER_PAGE));
        let cur = 0;

        const rowEls   = [0,1,2].map(i => document.getElementById('shelf-row-' + i));
        const pag      = document.getElementById('shelf-pagination');
        const dotsWrap = document.getElementById('page-dots');
        const prevBtn  = document.getElementById('prev-btn');
        const nextBtn  = document.getElementById('next-btn');

        if (totalPages > 1) {
          for (let i = 0; i < totalPages; i++) {
            const d = document.createElement('button');
            d.className = 'page-dot';
            d.setAttribute('aria-label', (i+1) + '페이지');
            d.addEventListener('click', function(){ goTo(i); });
            dotsWrap.appendChild(d);
          }
          pag.style.display = 'flex';
        }

        function makeAutoCard(book) {
          var d = document.createElement('div');
          d.className = 'book-cover-auto';
          d.style.background = book.color;
          return d;
        }
        function makeCover(book) {
          // 1순위: 글에 지정한 thumbnail
          if (book.cover) {
            var img = document.createElement('img');
            img.src = book.cover;
            img.alt = book.name;
            img.onerror = function() { img.replaceWith(makeAutoCard(book)); };
            return img;
          }
          // 2순위: /covers/책제목.png|jpg|webp|svg
          var exts = ['png', 'jpg', 'webp', 'svg'];
          var idx = 0;
          var img = document.createElement('img');
          var base = '/covers/' + encodeURIComponent(book.name) + '.';
          img.src = base + exts[idx];
          img.alt = book.name;
          img.onerror = function() {
            idx++;
            if (idx < exts.length) { img.src = base + exts[idx]; return; }
            img.replaceWith(makeAutoCard(book));
          };
          return img;
        }

        function render(page) {
          var slice = books.slice(page * PER_PAGE, page * PER_PAGE + PER_PAGE);
          rowEls.forEach(function(rowEl, ri) {
            rowEl.innerHTML = '';
            var rowBooks = slice.slice(ri * PER_ROW, ri * PER_ROW + PER_ROW);
            // 해당 행에 책이 없으면 선반 자체를 숨김
            var rowContainer = rowEl.closest('.shelf-row');
            if (rowContainer) rowContainer.style.display = rowBooks.length > 0 ? '' : 'none';
            rowBooks.forEach(function(book) {
              var a = document.createElement('a');
              a.href = '/series/' + encodeURIComponent(book.name);
              a.className = 'book-item';

              var cv = document.createElement('div');
              cv.className = 'book-cover';
              cv.appendChild(makeCover(book));
              var sp = document.createElement('div');
              sp.className = 'book-spine';
              sp.style.background = book.color;
              cv.appendChild(sp);
              // 표지 위에 책 제목 얹기 (제목만, 길면 최대 2줄)
              var titleEl = document.createElement('div');
              titleEl.className = 'book-title-overlay';
              titleEl.textContent = book.name;
              cv.appendChild(titleEl);

              a.appendChild(cv);
              rowEl.appendChild(a);
            });
            for (var g = rowBooks.length; g < PER_ROW; g++) {
              var ghost = document.createElement('div');
              ghost.className = 'book-ghost';
              rowEl.appendChild(ghost);
            }
          });

          dotsWrap.querySelectorAll('.page-dot').forEach(function(d, i) {
            d.classList.toggle('active', i === page);
          });
          prevBtn.disabled = page === 0;
          nextBtn.disabled = page === totalPages - 1;
        }

        function goTo(page) { cur = page; render(cur); }
        prevBtn.addEventListener('click', function(){ goTo(Math.max(0, cur - 1)); });
        nextBtn.addEventListener('click', function(){ goTo(Math.min(totalPages - 1, cur + 1)); });
        render(0);
      })();
      </script>
    </div>
  </section>

  <!-- 사무장의 SNS -->
  <section class="section channels-section">
    <div class="container">
      <h2 class="section-title">주인장 SNS</h2>
      <p class="section-sub">블로그·유튜브 최신 소식과 X·카카오 바로가기</p>

      <div class="channels-grid" id="sns-grid" data-x-handle={social.xHandle}>

        <!-- 네이버 블로그: 최신글 자동 미리보기 -->
        <a class="channel-card feed-card" id="card-naver"
           href={social.naverUrl} target="_blank" rel="noopener noreferrer" aria-label="네이버 블로그">
          <div class="cc-head naver">
            <img class="cc-logo" src="/sns/naver-mark.svg" alt="" />
            <span class="cc-name">네이버 블로그</span>
          </div>
          <div class="cc-preview">
            <div class="cc-thumb cc-skel"></div>
            <p class="cc-title">최신 글을 불러오는 중…</p>
          </div>
          <span class="cc-btn naver-btn">블로그에서 보기 →</span>
        </a>

        <!-- 유튜브: 최신영상 썸네일 자동 미리보기 -->
        <a class="channel-card feed-card" id="card-youtube"
           href={social.youtubeUrl} target="_blank" rel="noopener noreferrer" aria-label="유튜브">
          <div class="cc-head youtube">
            <img class="cc-logo" src="/sns/youtube-mark.svg" alt="" />
            <span class="cc-name">유튜브</span>
          </div>
          <div class="cc-preview">
            <div class="cc-thumb cc-thumb-video cc-skel"></div>
            <p class="cc-title">최신 영상을 불러오는 중…</p>
          </div>
          <span class="cc-btn youtube-btn">채널에서 보기 →</span>
        </a>

        <!-- X: 공식 타임라인 임베드 위젯 -->
        <div class="channel-card embed-card">
          <div class="cc-head x">
            <img class="cc-logo" src="/sns/x-mark.svg" alt="" />
            <span class="cc-name">X</span>
          </div>
          <!-- PC: X 공식 타임라인 임베드 -->
          <div class="cc-embed" id="x-embed">
            <a class="twitter-timeline"
               data-height="320"
               data-chrome="noheader nofooter noborders transparent"
               data-dnt="true"
               href={`https://twitter.com/${social.xHandle}`}>@{social.xHandle}</a>
          </div>
          <!-- 모바일: 임베드가 차단되는 경우가 많아 정적 카드로 표시 -->
          <div class="cc-x-static">
            <img class="x-big" src="/sns/x-mark.svg" alt="" />
            <p class="cc-kakao-desc">법률 이슈와 생각을<br/>X(트위터)에서 만나보세요.</p>
          </div>
          <a class="cc-btn x-btn" href={`https://x.com/${social.xHandle}`}
             target="_blank" rel="noopener noreferrer">X에서 보기 →</a>
        </div>

        <!-- 카카오채널: 바로 채팅 -->
        <a class="channel-card kakao-card"
           href={social.kakaoUrl} target="_blank" rel="noopener noreferrer" aria-label="카카오채널">
          <div class="cc-head kakao">
            <img class="cc-logo" src="/sns/kakao-mark.svg" alt="" />
            <span class="cc-name">카카오채널</span>
          </div>
          <div class="cc-kakao">
            <img class="kakao-big" src="/sns/kakao-mark.svg" alt="" />
            <p class="cc-kakao-desc">궁금한 점이 있으신가요?<br/>카카오로 바로 채팅하세요.</p>
          </div>
          <span class="cc-btn kakao-btn">채팅하기 →</span>
        </a>
      </div>
    </div>

    <!-- 네이버·유튜브 최신 소식 채우기 -->
    <script is:inline>
    (function() {
      function setCard(cardId, data, fallbackText) {
        var card = document.getElementById(cardId);
        if (!card) return;
        var thumb = card.querySelector('.cc-thumb');
        var title = card.querySelector('.cc-title');
        if (!data) {
          // 못 가져오면: 스켈레톤만 거두고 안내 문구 — 링크 버튼은 그대로 동작
          if (thumb) thumb.style.display = 'none';
          if (title) title.textContent = fallbackText;
          return;
        }
        if (data.link) card.href = data.link;
        if (title) title.textContent = data.title || fallbackText;
        if (thumb) {
          if (data.thumbnail) {
            var img = document.createElement('img');
            img.src = data.thumbnail;
            img.alt = data.title || '';
            img.loading = 'lazy';
            img.onerror = function() { thumb.style.display = 'none'; };
            thumb.classList.remove('cc-skel');
            thumb.innerHTML = '';
            thumb.appendChild(img);
          } else {
            thumb.style.display = 'none';
          }
        }
      }

      fetch('/api/feeds')
        .then(function(r) { return r.ok ? r.json() : Promise.reject(); })
        .then(function(d) {
          setCard('card-naver', d.naver, '네이버 블로그 바로가기');
          setCard('card-youtube', d.youtube, '유튜브 채널 바로가기');
        })
        .catch(function() {
          setCard('card-naver', null, '네이버 블로그 바로가기');
          setCard('card-youtube', null, '유튜브 채널 바로가기');
        });
    })();
    </script>
    <!-- X 공식 위젯 (최신 트윗 타임라인을 자동으로 갱신) -->
    <script is:inline async src="https://platform.twitter.com/widgets.js" charset="utf-8"></script>
  </section>
</BaseLayout>

<style>
  /* ── 히어로 ── */
  .hero {
    padding: 5rem 0 4rem;
    border-bottom: 1px solid var(--border-soft);
    position: relative;
    overflow: hidden;
  }
  /* 배경 이미지: 블러 처리, 우측에서 스며드는 효과 */
  .hero::before {
    content: '';
    position: absolute;
    inset: -24px;
    background-image: url('/image/hero-bg.png');
    background-size: cover;
    background-position: center 25%;
    filter: blur(4px);
    transform: scale(1.05);
    opacity: 0.70;
    z-index: 0;
  }
  /* 왼쪽(텍스트 영역)은 크림색으로, 오른쪽은 이미지가 보이게 */
  .hero::after {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to right,
      var(--bg) 0%,
      var(--bg) 25%,
      rgba(250, 247, 242, 0.3) 55%,
      transparent 100%
    );
    z-index: 0;
  }
  .hero-inner { position: relative; z-index: 1; max-width: 620px; }
  .hero-sub {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.82rem;
    color: var(--accent);
    font-weight: 600;
    letter-spacing: 0.08em;
    margin-bottom: 1.1rem;
    background: var(--accent-bg);
    padding: 0.3rem 0.8rem;
    border-radius: 20px;
    border: 1px solid rgba(176, 90, 58, 0.2);
  }
  .hero-title {
    font-size: clamp(2rem, 5vw, 3rem);
    color: var(--text-main);
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
    line-height: 1.2;
  }
  .hero-desc {
    font-size: 1rem;
    color: var(--text-sub);
    line-height: 1.8;
  }

  /* ── 섹션 공통 ── */
  .section { padding: 4rem 0; }
  .section-title {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 1.4rem;
    color: var(--text-main);
    margin-bottom: 0.4rem;
  }
  .section-title::before {
    content: '';
    display: inline-block;
    width: 4px;
    height: 1.2em;
    background: var(--accent);
    border-radius: 2px;
    flex-shrink: 0;
  }
  .section-sub {
    font-size: 0.9rem;
    color: var(--text-muted);
    margin-bottom: 2rem;
    padding-left: 0.65rem;
  }

  /* ── 글 그리드 ── */
  .posts-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: 1.25rem;
    align-items: start; /* 카드가 같은 행 높이로 늘어나 빈 공간이 생기는 것 방지 */
  }

  /* ── 최근 포스팅 페이저 (한 편씩 넘김 + 본문 노출) ── */
  .recent-track {
    max-width: 680px;
    margin: 0 auto;
  }
  .recent-slide { width: 100%; }
  .recent-pagination {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.5rem;
  }

  /* 본문을 직접 보여주는 글 블록 */
  .recent-post {
    border: 1px solid var(--border-soft);
    border-radius: 14px;
    background: var(--bg-mid);
    box-shadow: var(--shadow-sm);
    padding: 1.75rem 1.85rem 1.5rem;
  }
  .rp-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.7rem;
    font-size: 0.82rem;
    color: var(--text-muted);
  }
  .rp-cat {
    color: var(--accent);
    font-weight: 600;
    background: var(--accent-bg);
    padding: 0.1rem 0.55rem;
    border-radius: 4px;
    font-size: 0.78rem;
  }
  .rp-title {
    font-size: 1.4rem;
    line-height: 1.35;
    color: var(--text-main);
    margin-bottom: 0.6rem;
    letter-spacing: -0.01em;
  }
  .rp-title a { color: inherit; text-decoration: none; }
  .rp-title a:hover { color: var(--accent); }
  .rp-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1.1rem;
  }
  .rp-tag { font-size: 0.78rem; color: var(--text-muted); text-decoration: none; }
  .rp-tag:hover { color: var(--accent); }

  /* 접힘/펼침 영역 */
  .rp-content {
    position: relative;
    overflow: hidden;
    transition: max-height 0.4s ease;
  }
  .rp-thumb {
    display: block;
    width: 100%;
    height: auto;
    border-radius: 10px;
    margin-bottom: 1.25rem;
  }
  /* 하단 페이드 (접혀 있을 때만) */
  .rp-fade {
    position: absolute;
    left: 0; right: 0; bottom: 0;
    height: 5rem;
    background: linear-gradient(to bottom, rgba(243,237,227,0), var(--bg-mid));
    pointer-events: none;
  }
  .rp-content.expanded .rp-fade { display: none; }

  /* 펼치기/접기 버튼 */
  .rp-toggle {
    display: block;
    width: 100%;
    margin-top: 1rem;
