---
import BaseLayout from '../layouts/BaseLayout.astro';
import PostCard from '../components/PostCard.astro';
import { getCollection } from 'astro:content';
import { isPublished } from '../lib/posts';

const allPosts = await getCollection('posts', isPublished);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
// 최신 글부터 최대 5편 — 한 편씩 페이지를 넘기며 봅니다.
const recentPosts = allPosts.slice(0, 5);

// 최근 포스팅은 카드가 아니라 본문(썸네일·이미지 포함)을 직접 보여줍니다.
// 각 글의 렌더링된 본문 컴포넌트와 표시용 날짜를 미리 준비합니다.
const recentRendered = await Promise.all(
  recentPosts.map(async (post) => {
    const { Content } = await post.render();
    const formattedDate = post.data.date.toLocaleDateString('ko-KR', {
      year: 'numeric', month: 'long', day: 'numeric',
    });
    return { post, Content, formattedDate };
  })
);

// 책별 커스텀 색상 — 없으면 자동 배색 (tags[0]이 책 제목)
const bookMeta: Record<string, { color: string }> = {
  '커피공부':   { color: '#c8956a' },
  '생각에세이': { color: '#8abb8a' },
  '소설독후감': { color: '#8ab0c8' },
};

// 자동 배색 팔레트 — 파스텔 일러스트 톤
const autoPalette = [
  '#c8c070', '#78b8b0', '#b0a0c8', '#c89080',
  '#88b8a8', '#d4a870', '#a8c8a0', '#c8a0b8',
];

// tags[0]을 책 제목으로 사용해 책 목록 자동 생성
const bookNames = [...new Set(allPosts.map(p => p.data.tags[0]))];
let paletteIndex = 0;

const bookshelf = bookNames.map(name => {
  const postsInBook = allPosts
    .filter(p => p.data.tags[0] === name)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  // 책 표지: 대표 표지로 지정한 글(bookCover) 우선, 없으면 가장 최신 글의 thumbnail
  const cover =
    postsInBook.find(p => p.data.bookCover && p.data.thumbnail)?.data.thumbnail ??
    postsInBook.find(p => p.data.thumbnail)?.data.thumbnail ??
    null;
  const color = bookMeta[name]?.color ?? autoPalette[paletteIndex++ % autoPalette.length];
  return { name, color, cover, count: postsInBook.length };
});

// SNS 링크 — 주소만 바꾸면 카드도 따라갑니다.
// (네이버·유튜브 '최신글/영상'은 /api/feeds 서버리스 함수가 실시간으로 채웁니다.)
const social = {
  naverUrl:   'https://blog.naver.com/lawyer_youngjune',
  youtubeUrl: 'https://www.youtube.com/@사무장박영준',
  xHandle:    'youngjune0529',
  kakaoUrl:   'https://pf.kakao.com/_ExjlsX/chat',
};
---

<BaseLayout>
  <!-- 히어로 -->
  <section class="hero">
    <div class="container hero-inner">
      <span class="hero-sub">보고 듣고 읽고 쓰는</span>
      <h1 class="hero-title">작은 책방</h1>
      <p class="hero-desc">
        법무사 사무소 현직 사무장의 생각과 기록이 담긴 공간
      </p>
    </div>
  </section>

  <!-- 최근 포스팅 -->
  {recentPosts.length > 0 && (
    <section class="section">
      <div class="container">
        <h2 class="section-title">최근 포스팅</h2>
        <!-- 한 편씩 넘겨 보는 페이저 (본문을 직접 노출) -->
        <div class="recent-pager" id="recent-pager">
          <div class="recent-track" id="recent-track">
            {recentRendered.map(({ post, Content, formattedDate }) => (
              <div class="recent-slide">
                <article class="recent-post">
                  <div class="rp-meta">
                    <a href={`/shelf/${post.data.category}`} class="rp-cat">{post.data.category}</a>
                    <time>{formattedDate}</time>
                  </div>
                  <h3 class="rp-title">
                    <a href={`/posts/${post.slug}`}>{post.data.title}</a>
                  </h3>
                  {post.data.tags.length > 0 && (
                    <div class="rp-tags">
                      {post.data.tags.map(t => <a href={`/tag/${t}`} class="rp-tag">#{t}</a>)}
                    </div>
                  )}
                  <div class="rp-content collapsed">
                    {post.data.thumbnail && (
                      <img class="rp-thumb" src={post.data.thumbnail} alt={post.data.title} />
                    )}
                    <div class="rp-body">
                      <Content />
                    </div>
                    <div class="rp-fade" aria-hidden="true"></div>
                  </div>
                  <button class="rp-toggle" type="button">펼쳐서 전체 보기 ▾</button>
                </article>
              </div>
            ))}
          </div>
          <div class="recent-pagination" id="recent-pagination">
            <button class="page-btn" id="recent-prev" aria-label="이전 글">←</button>
            <div class="page-dots" id="recent-dots"></div>
            <button class="page-btn" id="recent-next" aria-label="다음 글">→</button>
          </div>
        </div>

        <script is:inline>
        (function() {
          const track = document.getElementById('recent-track');
          if (!track) return;
          const slides = Array.prototype.slice.call(track.querySelectorAll('.recent-slide'));
          const dotsWrap = document.getElementById('recent-dots');

          // ── 본문을 전체 높이의 1/3만 보이도록 접기 + 펼치기 토글 ──
          // (페이저가 슬라이드를 숨기기 전, 모두 보이는 상태에서 높이를 측정)
          slides.forEach(function(slide) {
            const content = slide.querySelector('.rp-content');
            const toggle  = slide.querySelector('.rp-toggle');
            if (!content || !toggle) return;
            let collapsedH = 0;

            function measure() {
              const full = content.scrollHeight;
              if (full === 0) return;           // 숨겨진 슬라이드(측정 불가)는 건너뜀
              if (content.classList.contains('expanded')) return;
              collapsedH = Math.max(160, Math.round(full / 3));
              // 본문이 짧아 접을 필요가 없으면: 전체 표시 + 버튼 숨김
              if (full <= collapsedH + 80) {
                content.classList.remove('collapsed');
                content.style.maxHeight = 'none';
                toggle.style.display = 'none';
              } else {
                content.classList.add('collapsed');
                content.style.maxHeight = collapsedH + 'px';
                toggle.style.display = '';
              }
            }
            measure();
            // 이미지가 늦게 로드돼 높이가 바뀌면 다시 계산 (접힌 상태일 때만)
            slide.querySelectorAll('img').forEach(function(img) {
              if (!img.complete) img.addEventListener('load', measure);
            });

            toggle.addEventListener('click', function() {
              const expanded = content.classList.toggle('expanded');
              content.classList.toggle('collapsed', !expanded);
              if (expanded) {
                content.style.maxHeight = content.scrollHeight + 'px';
                toggle.textContent = '접기 ▴';
              } else {
                content.style.maxHeight = collapsedH + 'px';
                toggle.textContent = '펼쳐서 전체 보기 ▾';
                slide.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
              }
            });
          });
          const prevBtn  = document.getElementById('recent-prev');
          const nextBtn  = document.getElementById('recent-next');
          const pag      = document.getElementById('recent-pagination');
          let cur = 0;

          // 글이 1편뿐이면 페이지 컨트롤 숨김
          if (slides.length <= 1) { if (pag) pag.style.display = 'none'; return; }

          slides.forEach(function(s, i) {
            const d = document.createElement('button');
            d.className = 'page-dot';
            d.setAttribute('aria-label', (i + 1) + '번째 글');
            d.addEventListener('click', function() { go(i); });
            dotsWrap.appendChild(d);
          });

          function render() {
            slides.forEach(function(s, i) { s.style.display = i === cur ? '' : 'none'; });
            dotsWrap.querySelectorAll('.page-dot').forEach(function(d, i) {
              d.classList.toggle('active', i === cur);
            });
            prevBtn.disabled = cur === 0;
            nextBtn.disabled = cur === slides.length - 1;
          }
          function go(i) { cur = Math.max(0, Math.min(slides.length - 1, i)); render(); }
          prevBtn.addEventListener('click', function() { go(cur - 1); });
          nextBtn.addEventListener('click', function() { go(cur + 1); });
          render();
        })();
        </script>
      </div>
    </section>
  )}

  <!-- 영준의 책장 — 책꽂이 -->
  <section class="section shelf-section">
    <div class="container">
      <h2 class="section-title">이야기 진열대</h2>
