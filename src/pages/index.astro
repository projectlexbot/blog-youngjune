    color: var(--text-main);
    letter-spacing: -0.01em;
  }

  /* 미리보기 본문 (네이버·유튜브 공통) */
  .cc-preview { padding: 0.85rem 0.95rem; flex: 1; }
  .cc-thumb {
    width: 100%;
    aspect-ratio: 16 / 10;
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-light);
    margin-bottom: 0.7rem;
  }
  .cc-thumb-video { aspect-ratio: 16 / 9; }
  .cc-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.3s;
  }
  a.channel-card:hover .cc-thumb img { transform: scale(1.04); }
  .cc-title {
    font-size: 0.9rem;
