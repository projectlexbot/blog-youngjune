    transition: background 0.15s;
  }
  .rp-toggle:hover { background: rgba(176, 90, 58, 0.14); }

  /* 본문 타이포그래피 (PostLayout과 동일 톤) */
  .rp-body :global(p) { margin-bottom: 1.1rem; color: var(--text-main); line-height: 1.85; }
  .rp-body :global(h2) { font-size: 1.2rem; margin: 1.8rem 0 0.8rem; color: var(--text-main); }
  .rp-body :global(h3) { font-size: 1.05rem; margin: 1.4rem 0 0.6rem; color: var(--text-main); }
  .rp-body :global(img) {
    display: block; max-width: 100%; height: auto;
    margin: 1.25rem auto; border-radius: 8px;
    box-shadow: 0 2px 12px rgba(0, 0, 0, 0.08);
  }
  .rp-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    margin: 1.2rem 0; padding: 0.6rem 1.1rem;
    background: var(--bg-light); border-radius: 0 6px 6px 0; color: var(--text-sub);
  }
  .rp-body :global(strong) { color: var(--accent-dark); font-weight: 700; }
  .rp-body :global(a) { color: var(--accent); text-decoration: underline; text-underline-offset: 3px; }
  .rp-body :global(ul), .rp-body :global(ol) { padding-left: 1.4rem; margin-bottom: 1.1rem; }
  .rp-body :global(li) { margin-bottom: 0.35rem; }

  @media (max-width: 640px) {
    .recent-post { padding: 1.2rem 1.15rem 1.1rem; background: #fffdf9; }
    .rp-title { font-size: 1.2rem; }
    .rp-body :global(p) { font-size: 0.95rem; line-height: 1.8; }
    /* 모바일 카드 배경(#fffdf9)에 맞춰 페이드 끝 색 정렬 */
    .rp-fade { background: linear-gradient(to bottom, rgba(255,253,249,0), #fffdf9); }
  }

  /* ── 책꽂이 ── */
  .shelf-section { background: var(--bg); }

  /* 전체 가구 프레임 — 일러스트 스타일 */
  .bookshelf-wrap {
    background: #f8ede0;
    border-radius: 12px;
    padding: 20px 28px 24px;
    border: 1.5px solid #c8a46a;
    box-shadow: 0 4px 24px rgba(160, 100, 40, 0.10), 0 1px 6px rgba(160, 100, 40, 0.06);
    position: relative;
    overflow: hidden;
  }

  /* 장식 레이어 (식물·배경 책등) */
  .shelf-deco {
    position: absolute;
    inset: 0;
    pointer-events: none;
    z-index: 0;
  }
  .deco-ivy {
    position: absolute;
    top: -2px;
