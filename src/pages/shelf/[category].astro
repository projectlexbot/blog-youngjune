---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  const categories = [...new Set(allPosts.map(p => p.data.category))];
  return categories.map(category => {
    const catPosts = allPosts.filter(p => p.data.category === category);
    const seriesNames = [...new Set(catPosts.map(p => p.data.tags[0]))];
    return { params: { category }, props: { seriesNames, catPosts } };
  });
}

const { category } = Astro.params;
const { seriesNames, catPosts } = Astro.props;

const autoPalette = [
  '#c8c070', '#78b8b0', '#b0a0c8', '#c89080',
  '#88b8a8', '#d4a870', '#a8c8a0', '#c8a0b8',
];
const bookMeta: Record<string, { color: string }> = {
  '커피공부':   { color: '#c8956a' },
  '생각에세이': { color: '#8abb8a' },
  '소설독후감': { color: '#8ab0c8' },
};

const books = seriesNames.map((name, i) => {
  const postsInBook = catPosts
    .filter(p => p.data.tags[0] === name)
    .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());
  // 대표 표지로 지정한 글(bookCover) 우선, 없으면 가장 최신 글의 thumbnail
  const cover =
    postsInBook.find(p => p.data.bookCover && p.data.thumbnail)?.data.thumbnail ??
    postsInBook.find(p => p.data.thumbnail)?.data.thumbnail ??
    null;
  return {
    name,
    color: bookMeta[name]?.color ?? autoPalette[i % autoPalette.length],
    cover,
    count: postsInBook.length,
  };
});
---

<BaseLayout title={category} description={`${category} 서가의 책 목록입니다.`}>
  <div class="shelf-page">
    <div class="container">
      <header class="page-header">
        <p class="breadcrumb"><a href="/">홈</a> / {category}</p>
        <h1 class="page-title">{category}</h1>
        <p class="page-meta">책 {books.length}권 · 글 {catPosts.length}편</p>
      </header>

      {books.length > 0 ? (
        <div
          class="bookshelf-wrap"
          id="bookshelf"
          data-books={JSON.stringify(books)}
        >
          <div class="shelf-unit">
            <div class="shelf-row"><div class="shelf-books" id="shelf-row-0"></div><div class="shelf-board"></div></div>
            <div class="shelf-row"><div class="shelf-books" id="shelf-row-1"></div><div class="shelf-board"></div></div>
            <div class="shelf-row"><div class="shelf-books" id="shelf-row-2"></div><div class="shelf-board"></div></div>
          </div>
          <div class="shelf-pagination" id="shelf-pagination">
            <button class="page-btn" id="prev-btn">←</button>
            <div class="page-dots" id="page-dots"></div>
            <button class="page-btn" id="next-btn">→</button>
          </div>
        </div>
      ) : (
        <p class="empty">아직 글이 없습니다.</p>
      )}
    </div>
  </div>

  <script is:inline>
  (function() {
    var wrap = document.getElementById('bookshelf');
    if (!wrap) return;
    var books = JSON.parse(wrap.dataset.books || '[]');
    var PER_PAGE = 9, PER_ROW = 3;
    var totalPages = Math.max(1, Math.ceil(books.length / PER_PAGE));
    var cur = 0;

    var rowEls   = [0,1,2].map(function(i){ return document.getElementById('shelf-row-' + i); });
    var pag      = document.getElementById('shelf-pagination');
    var dotsWrap = document.getElementById('page-dots');
    var prevBtn  = document.getElementById('prev-btn');
    var nextBtn  = document.getElementById('next-btn');

    if (totalPages > 1) {
      for (var i = 0; i < totalPages; i++) {
        (function(idx){
          var d = document.createElement('button');
          d.className = 'page-dot';
          d.addEventListener('click', function(){ goTo(idx); });
          dotsWrap.appendChild(d);
        })(i);
      }
      pag.style.display = 'flex';
    }

    function makeAutoCard(book) {
      var d = document.createElement('div');
      d.className = 'book-cover-auto';
      d.style.background = book.color;
      var s = document.createElement('span');
      s.className = 'book-cover-letter';
      s.textContent = Array.from(book.name)[0];
      d.appendChild(s);
      return d;
    }
    function makeCover(book) {
      if (book.cover) {
        var img = document.createElement('img');
        img.src = book.cover;
        img.alt = book.name;
        img.onerror = function() { img.replaceWith(makeAutoCard(book)); };
        return img;
      }
      var exts = ['png', 'jpg', 'webp', 'svg'];
      var idx = 0;
      var img = document.createElement('img');
      var base = '/covers/' + encodeURIComponent(book.name) + '.';
      img.src = base + exts[idx];
      img.alt = book.name;
      img.onerror = function() {
        idx++;
        if (idx < exts.length) { img.src = base + exts[idx]; return; }
        img.replaceWith(makeAutoCard(book));
      };
      return img;
    }

    function render(page) {
      var slice = books.slice(page * PER_PAGE, page * PER_PAGE + PER_PAGE);
      rowEls.forEach(function(rowEl, ri) {
        rowEl.innerHTML = '';
        var rowBooks = slice.slice(ri * PER_ROW, ri * PER_ROW + PER_ROW);
        var rowContainer = rowEl.closest('.shelf-row');
        if (rowContainer) rowContainer.style.display = rowBooks.length > 0 ? '' : 'none';
        rowBooks.forEach(function(book) {
          var a = document.createElement('a');
          a.href = '/series/' + encodeURIComponent(book.name);
          a.className = 'book-item';
          var cv = document.createElement('div');
          cv.className = 'book-cover';
          cv.appendChild(makeCover(book));
          var sp = document.createElement('div');
          sp.className = 'book-spine';
          sp.style.background = book.color;
          cv.appendChild(sp);
          var info = document.createElement('div');
          info.className = 'book-info';
          info.innerHTML =
            '<p class="book-count">' + book.count + '편</p>' +
            '<p class="book-name">' + book.name + '</p>';
          a.appendChild(cv); a.appendChild(info);
          rowEl.appendChild(a);
        });
        for (var g = rowBooks.length; g < PER_ROW; g++) {
          var ghost = document.createElement('div');
          ghost.className = 'book-ghost';
          rowEl.appendChild(ghost);
        }
      });
      dotsWrap.querySelectorAll('.page-dot').forEach(function(d, i) {
        d.classList.toggle('active', i === page);
      });
      if (prevBtn) prevBtn.disabled = page === 0;
      if (nextBtn) nextBtn.disabled = page === totalPages - 1;
    }

    function goTo(page) { cur = page; render(cur); }
    prevBtn?.addEventListener('click', function(){ goTo(Math.max(0, cur-1)); });
    nextBtn?.addEventListener('click', function(){ goTo(Math.min(totalPages-1, cur+1)); });
    render(0);
  })();
  </script>
</BaseLayout>

<style>
  .shelf-page { padding: 3.5rem 0 5rem; }
  .page-header { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border-soft); }
  .breadcrumb { font-size: 0.83rem; color: var(--text-muted); margin-bottom: 0.75rem; }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb a:hover { color: var(--accent); }
  .page-title { font-size: 2rem; color: var(--text-main); margin-bottom: 0.4rem; }
  .page-meta { font-size: 0.88rem; color: var(--text-muted); }
  .empty { color: var(--text-muted); padding: 2rem 0; }

  .bookshelf-wrap {
    background: #f8ede0;
    border-radius: 12px;
    padding: 20px 28px 24px;
    border: 1.5px solid #c8a46a;
    box-shadow: 0 4px 24px rgba(160, 100, 40, 0.10), 0 1px 6px rgba(160, 100, 40, 0.06);
    position: relative;
    overflow: hidden;
  }
  .shelf-unit { display: flex; flex-direction: column; position: relative; z-index: 1; }
  .shelf-row { display: flex; flex-direction: column; }
  .shelf-books {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem 2rem;
    padding: 1.75rem 0.5rem 1.25rem;
    align-items: flex-end;
    min-height: 220px;
  }
  .shelf-board {
    background: #c89450;
    height: 10px;
    border-radius: 2px;
    margin: 0 -4px;
    box-shadow: 0 3px 10px rgba(140, 90, 30, 0.18), inset 0 1px 0 rgba(255, 210, 140, 0.4);
    position: relative;
    z-index: 2;
  }
  .shelf-pagination {
    display: none;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    margin-top: 1.25rem;
  }
  .page-btn {
    background: rgba(160, 100, 40, 0.08);
    border: 1px solid rgba(160, 100, 40, 0.20);
    color: var(--accent);
    width: 36px; height: 36px;
    border-radius: 50%;
    font-size: 1rem;
    cursor: pointer;
    display: flex; align-items: center; justify-content: center;
    transition: background 0.15s;
  }
  .page-btn:hover:not(:disabled) { background: rgba(160, 100, 40, 0.15); }
  .page-btn:disabled { opacity: 0.3; cursor: default; }
  .page-dots { display: flex; gap: 0.5rem; }
  .page-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: rgba(160, 100, 40, 0.22);
    border: none; cursor: pointer; padding: 0;
    transition: background 0.15s, transform 0.15s;
  }
  .page-dot.active { background: var(--accent); transform: scale(1.3); }

  :global(.book-item) {
    display: flex; flex-direction: column; align-items: center;
    cursor: pointer; text-decoration: none;
    transition: transform 0.28s cubic-bezier(.34,1.4,.64,1);
    transform-origin: bottom center;
  }
  :global(.book-item:hover) { transform: translateY(-16px) scale(1.04); z-index: 2; }
  :global(.book-ghost) { visibility: hidden; }
  :global(.book-cover) {
    position: relative; width: 100%; aspect-ratio: 3/4;
    border-radius: 2px 7px 7px 2px; overflow: hidden;
    box-shadow: -4px 0 0 0 rgba(0,0,0,0.12), 5px 7px 18px rgba(140,100,50,0.22), inset -2px 0 6px rgba(0,0,0,0.07);
  }
  :global(.book-cover img) { width: 100%; height: 100%; object-fit: cover; display: block; }
  :global(.book-cover-auto) { width: 100%; height: 100%; display: flex; align-items: center; justify-content: center; }
  :global(.book-cover-letter) {
    font-family: var(--serif); font-size: 3rem; font-weight: 700;
    color: rgba(255,255,255,0.88); text-shadow: 0 2px 8px rgba(0,0,0,0.18);
  }
  :global(.book-spine) { position: absolute; left: 0; top: 0; width: 11px; height: 100%; opacity: 0.75; }
  :global(.book-info) { margin-top: 0.85rem; text-align: center; padding: 0 0.15rem; }
  :global(.book-count) { font-size: 0.7rem; color: var(--text-muted) !important; margin-bottom: 0.15rem; }
  :global(.book-name) { font-family: var(--serif) !important; font-size: 0.95rem; font-weight: 700; color: var(--text-main) !important; margin-bottom: 0.2rem; }
  :global(.book-desc) { font-size: 0.72rem; color: var(--text-sub) !important; line-height: 1.4; }
</style>
