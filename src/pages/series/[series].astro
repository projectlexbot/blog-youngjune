---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { isPublished } from '../../lib/posts';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', isPublished);
  const seriesNames = [...new Set(allPosts.map(p => p.data.tags[0]))];

  const palette = ['#c8956a', '#8abb8a', '#8ab0c8', '#b0a0c8', '#c8a0b8', '#88b8a8', '#d4a870'];

  return seriesNames.map(series => {
    const seriesPosts = allPosts
      .filter(p => p.data.tags[0] === series)
      .sort((a, b) => a.data.date.getTime() - b.data.date.getTime()); // 오래된 순(1편부터)

    const category = seriesPosts[0]?.data.category ?? '';
    // 표지: 대표 표지(bookCover) 우선, 없으면 썸네일 있는 글
    const cover =
      seriesPosts.find(p => p.data.bookCover && p.data.thumbnail)?.data.thumbnail ??
      seriesPosts.find(p => p.data.thumbnail)?.data.thumbnail ??
      null;
    // 책 소개: 대표 글의 bookIntro 우선, 없으면 bookIntro가 있는 글
    // (포스팅의 한 줄 소개(description)와는 별개 — 서로 겹치지 않음)
    const intro =
      seriesPosts.find(p => p.data.bookCover && p.data.bookIntro)?.data.bookIntro ??
      seriesPosts.find(p => p.data.bookIntro)?.data.bookIntro ??
      '';
    const firstDate = seriesPosts[0]?.data.date ?? null;
    const lastDate = seriesPosts[seriesPosts.length - 1]?.data.date ?? null;
    const color = palette[[...series].reduce((s, c) => s + c.charCodeAt(0), 0) % palette.length];

    return {
      params: { series },
      props: { posts: seriesPosts, category, cover, intro, firstDate, lastDate, color },
    };
  });
}

const { series } = Astro.params;
const { posts, category, cover, intro, firstDate, lastDate, color } = Astro.props;

const fmt = (d) =>
  d ? d.toLocaleDateString('ko-KR', { year: 'numeric', month: 'long', day: 'numeric' }) : '';
const firstLetter = Array.from(series ?? '')[0] ?? '책';
---

<BaseLayout title={series} description={intro || `${series} 시리즈의 글 목록입니다.`} image={cover ?? undefined}>
  <div class="container series-page">
    <p class="breadcrumb">
      <a href="/">홈</a>
      {category && <> / <a href={`/shelf/${category}`}>{category}</a></>}
      {' '}/ {series}
    </p>

    <!-- 책 정보 헤더: [표지] [제목·소개·업로드일] -->
    <header class="series-head">
      <div class="series-cover">
        {cover
          ? <img src={cover} alt={series} />
          : <div class="series-cover-auto" style={`background:${color}`}><span>{firstLetter}</span></div>}
      </div>
      <div class="series-meta">
        <h1 class="series-title">{series}</h1>
        {intro && <p class="series-intro">{intro}</p>}
        <dl class="series-dates">
          <div><dt>최초 업로드</dt><dd>{fmt(firstDate)}</dd></div>
          <div><dt>마지막 업로드</dt><dd>{fmt(lastDate)}</dd></div>
        </dl>
      </div>
    </header>

    <hr class="series-divider" />

    <!-- 글 목록 + 정렬 토글 -->
    <div class="series-toolbar">
      <span class="series-count">총 {posts.length}편</span>
      <div class="sort-toggle" id="sort-toggle">
        <button class="sort-btn active" data-order="old" type="button">오래된순</button>
        <button class="sort-btn" data-order="new" type="button">최신순</button>
      </div>
    </div>

    <div class="posts-list" id="posts-list">
      {posts.map(post => (
        <div class="post-row" data-time={post.data.date.getTime()}>
          <PostCard
            title={post.data.title}
            date={post.data.date}
            category={post.data.category}
            slug={post.slug}
            description={post.data.description}
            tags={post.data.tags}
          />
        </div>
      ))}
    </div>
  </div>

  <script is:inline>
  (function() {
    var list = document.getElementById('posts-list');
    var toggle = document.getElementById('sort-toggle');
    if (!list || !toggle) return;
    var rows = Array.prototype.slice.call(list.querySelectorAll('.post-row'));

    toggle.addEventListener('click', function(e) {
      var btn = e.target.closest('.sort-btn');
      if (!btn) return;
      var order = btn.dataset.order;
      toggle.querySelectorAll('.sort-btn').forEach(function(b) {
        b.classList.toggle('active', b === btn);
      });
      var sorted = rows.slice().sort(function(a, b) {
        var ta = +a.dataset.time, tb = +b.dataset.time;
        return order === 'new' ? tb - ta : ta - tb;
      });
      sorted.forEach(function(r) { list.appendChild(r); });
    });
  })();
  </script>
</BaseLayout>

<style>
  /* 좌우 여백은 .container 유지, 상하만 지정 */
  .series-page { padding-top: 3rem; padding-bottom: 5rem; }
  .breadcrumb { font-size: 0.83rem; color: var(--text-muted); margin-bottom: 1.5rem; }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb a:hover { color: var(--accent); }

  /* 책 정보 헤더 */
  .series-head {
    display: flex;
    gap: 1.5rem;
    align-items: flex-start;
  }
  .series-cover {
    flex-shrink: 0;
    width: 132px;
    aspect-ratio: 3 / 4;
    border-radius: 3px 8px 8px 3px;
    overflow: hidden;
    box-shadow: -4px 0 0 0 rgba(0,0,0,0.10), 5px 7px 18px rgba(140, 100, 50, 0.22);
  }
  .series-cover img { width: 100%; height: 100%; object-fit: cover; display: block; }
  .series-cover-auto {
    width: 100%; height: 100%;
    display: flex; align-items: center; justify-content: center;
  }
  .series-cover-auto span {
    font-family: var(--serif); font-size: 2.6rem; font-weight: 700;
    color: rgba(255,255,255,0.9); text-shadow: 0 2px 8px rgba(0,0,0,0.18);
  }

  .series-meta { flex: 1; min-width: 0; padding-top: 0.25rem; }
  .series-title {
    font-size: 1.7rem; color: var(--text-main); margin-bottom: 0.6rem;
    word-break: keep-all; overflow-wrap: break-word;
  }
  .series-intro {
    font-size: 0.95rem; color: var(--text-sub); line-height: 1.65;
    margin-bottom: 1rem; word-break: keep-all;
  }
  .series-dates { display: flex; flex-direction: column; gap: 0.3rem; }
  .series-dates > div { display: flex; gap: 0.6rem; font-size: 0.85rem; }
  .series-dates dt { color: var(--text-muted); min-width: 5.2rem; }
  .series-dates dd { color: var(--text-sub); }

  .series-divider { margin: 2rem 0 1.25rem; }

  /* 정렬 툴바 */
  .series-toolbar {
    display: flex; align-items: center; justify-content: space-between;
    margin-bottom: 1.25rem;
  }
  .series-count { font-size: 0.88rem; color: var(--text-muted); }
  .sort-toggle {
    display: inline-flex;
    border: 1px solid var(--border); border-radius: 8px; overflow: hidden;
  }
  .sort-btn {
    padding: 0.4rem 0.85rem; background: transparent; border: none;
    font-size: 0.83rem; color: var(--text-sub); cursor: pointer; font-family: inherit;
  }
  .sort-btn.active { background: var(--accent); color: #fff; font-weight: 600; }

  .posts-list { display: flex; flex-direction: column; gap: 1rem; }

  @media (max-width: 640px) {
    .series-page { padding-top: 2rem; padding-bottom: 3rem; }
    .breadcrumb { margin-bottom: 1rem; }
    .series-head { gap: 1rem; }
    .series-cover { width: 92px; }
    .series-title { font-size: 1.3rem; }
    .series-intro { font-size: 0.9rem; }
    .series-dates > div { font-size: 0.8rem; }
    .series-dates dt { min-width: 4.6rem; }
  }
</style>
