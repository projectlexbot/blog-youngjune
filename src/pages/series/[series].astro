---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';

export async function getStaticPaths() {
  const allPosts = await getCollection('posts', ({ data }) => !data.draft);
  const seriesNames = [...new Set(allPosts.map(p => p.data.tags[0]))];
  return seriesNames.map(series => {
    const seriesPosts = allPosts
      .filter(p => p.data.tags[0] === series)
      .sort((a, b) => a.data.date.getTime() - b.data.date.getTime()); // 오래된 순(1편부터)
    const category = seriesPosts[0]?.data.category ?? '';
    return { params: { series }, props: { posts: seriesPosts, category } };
  });
}

const { series } = Astro.params;
const { posts, category } = Astro.props;
---

<BaseLayout title={series} description={`${series} 시리즈의 글 목록입니다.`}>
  <div class="container list-page">
    <header class="page-header">
      <p class="breadcrumb">
        <a href="/">홈</a>
        {category && <> / <a href={`/shelf/${category}`}>{category}</a></>}
        {' '}/ {series}
      </p>
      <h1>{series}</h1>
      <p class="post-count">{posts.length}편의 글</p>
    </header>

    <div class="posts-list">
      {posts.map((post, i) => (
        <PostCard
          title={post.data.title}
          date={post.data.date}
          category={post.data.category}
          slug={post.slug}
          description={post.data.description}
          tags={post.data.tags}
        />
      ))}
    </div>
  </div>
</BaseLayout>

<style>
  .list-page { padding: 3.5rem 0 5rem; }
  .page-header { margin-bottom: 2.5rem; padding-bottom: 1.5rem; border-bottom: 1px solid var(--border-soft); }
  .breadcrumb { font-size: 0.83rem; color: var(--text-muted); margin-bottom: 0.75rem; }
  .breadcrumb a { color: var(--text-muted); }
  .breadcrumb a:hover { color: var(--accent); }
  h1 { font-size: 2rem; color: var(--text-main); word-break: keep-all; overflow-wrap: break-word; }
  .post-count { font-size: 0.88rem; color: var(--text-muted); margin-top: 0.4rem; }
  .posts-list { display: flex; flex-direction: column; gap: 1rem; }

  @media (max-width: 640px) {
    .list-page { padding: 2.25rem 0 3rem; }
    .page-header { margin-bottom: 1.75rem; padding-bottom: 1.1rem; }
    h1 { font-size: 1.5rem; }
  }
</style>
