---
interface Props {
  title: string;
  date: Date;
  category: string;
  slug: string;
  description?: string;
  tags?: string[];
}
const { title, date, category, slug, description, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card">
  <div class="card-meta">
    <a href={`/shelf/${category}`} class="card-cat">{category}</a>
    <time>{formattedDate}</time>
  </div>
  <!-- 제목 링크가 카드 전체를 덮어, 카드 어디를 눌러도 글로 이동 (stretched link) -->
  <h2 class="card-title"><a href={`/posts/${slug}`}>{title}</a></h2>
  {description && <p class="card-desc">{description}</p>}
  {tags.length > 0 && (
    <div class="card-tags">
      {tags.map(t => <span class="tag">#{t}</span>)}
    </div>
  )}
</article>

<style>
  .post-card {
    position: relative; /* stretched link 기준점 */
    border: 1px solid var(--border-soft);
    border-left: 3px solid var(--border);
    border-radius: 10px;
    background: var(--bg-mid);
    box-shadow: var(--shadow-sm);
    padding: 1.5rem 1.75rem;
    transition: border-color 0.2s, border-left-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .post-card:hover {
    border-color: var(--border-soft);
    border-left-color: var(--accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .card-meta {
    position: relative; /* 카테고리 링크를 덮개 위로 */
    z-index: 1;
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
    font-size: 0.82rem;
    color: var(--text-muted);
  }
  .card-cat {
    color: var(--accent);
    font-weight: 600;
    background: var(--accent-bg);
    padding: 0.1rem 0.55rem;
    border-radius: 4px;
    font-size: 0.78rem;
  }
  .card-cat:hover { background: var(--border); }

  .card-title {
    font-size: 1.15rem;
    color: var(--text-main);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
    word-break: keep-all;
    overflow-wrap: break-word;
  }
  .card-title a { color: inherit; }
  .card-title a:hover { color: var(--accent); }
  /* 카드 전체를 덮는 투명 클릭 영역 */
  .card-title a::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--text-sub);
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.65;
    word-break: keep-all;
    overflow-wrap: break-word;
  }

  .card-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .tag {
    font-size: 0.78rem;
    color: var(--text-muted);
    word-break: keep-all;
  }

  @media (max-width: 640px) {
    .post-card {
      align-self: start;
      background: #fffdf9;
      border-left-width: 2px;
      border-radius: 12px;
      padding: 1.05rem 1.15rem;
    }
    .card-meta { margin-bottom: 0.4rem; font-size: 0.76rem; gap: 0.55rem; }
    .card-cat { font-size: 0.72rem; padding: 0.08rem 0.45rem; }
    .card-title { font-size: 1.05rem; margin-bottom: 0.35rem; line-height: 1.45; }
    .card-desc { font-size: 0.85rem; margin-bottom: 0.55rem; line-height: 1.55; }
    .card-tags { gap: 0.4rem; }
    .tag { font-size: 0.72rem; }
  }
</style>
