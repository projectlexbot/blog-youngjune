---
interface Props {
  title: string;
  date: Date;
  category: string;
  slug: string;
  description?: string;
  tags?: string[];
}
const { title, date, category, slug, description, tags = [] } = Astro.props;

const formattedDate = date.toLocaleDateString('ko-KR', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
});
---

<article class="post-card">
  <a href={`/posts/${slug}`} class="card-link">
    <div class="card-meta">
      <a href={`/shelf/${category}`} class="card-cat">{category}</a>
      <time>{formattedDate}</time>
    </div>
    <h2 class="card-title">{title}</h2>
    {description && <p class="card-desc">{description}</p>}
    {tags.length > 0 && (
      <div class="card-tags">
        {tags.map(t => <span class="tag">#{t}</span>)}
      </div>
    )}
  </a>
</article>

<style>
  .post-card {
    border: 1px solid var(--border-soft);
    border-left: 3px solid var(--border);
    border-radius: 10px;
    background: var(--bg-mid);
    box-shadow: var(--shadow-sm);
    transition: border-color 0.2s, border-left-color 0.2s, box-shadow 0.2s, transform 0.2s;
  }
  .post-card:hover {
    border-color: var(--border-soft);
    border-left-color: var(--accent);
    box-shadow: var(--shadow-md);
    transform: translateY(-2px);
  }

  .card-link {
    display: block;
    padding: 1.5rem 1.75rem;
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 0.6rem;
    font-size: 0.82rem;
    color: var(--text-muted);
  }

  .card-cat {
    color: var(--accent);
    font-weight: 600;
    background: var(--accent-bg);
    padding: 0.1rem 0.55rem;
    border-radius: 4px;
    font-size: 0.78rem;
  }

  .card-title {
    font-size: 1.15rem;
    color: var(--text-main);
    margin-bottom: 0.5rem;
    letter-spacing: -0.01em;
  }

  .card-desc {
    font-size: 0.9rem;
    color: var(--text-sub);
    margin-bottom: 0.75rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    line-height: 1.65;
  }

  .card-tags {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }

  .tag {
    font-size: 0.78rem;
    color: var(--text-muted);
  }

  @media (max-width: 640px) {
    .card-link { padding: 1.15rem 1.25rem; }
    .card-title { font-size: 1.08rem; }
    .card-desc { font-size: 0.86rem; }
  }
</style>
